# Use the below flags to enable the Analytics, ActivityPub, or local DB containers
# COMPOSE_PROFILES=analytics,activitypub
# Add "local-db" to COMPOSE_PROFILES to start a local MySQL container instead of using an external DB
# COMPOSE_PROFILES=local-db

# --- Site Configuration ---
# Public URL Ghost will be served at
GHOST_URL=https://example.com

# Ghost domain (used by Caddy for automatic HTTPS)
DOMAIN=example.com

# Ghost Admin domain
# If you have Ghost Admin setup on a separate domain uncomment the line below
# ADMIN_DOMAIN=

# Ghost ports
HTTP_PORT=80
HTTPS_PORT=443

# --- Database Configuration ---
# For an external database (e.g. AWS RDS), set DB_HOST to the remote host.
# For a local MySQL container, add "local-db" to COMPOSE_PROFILES and leave DB_HOST unset (defaults to "db").
DB_HOST=database-1.example.eu-central-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=ghost
DB_PASSWORD=ghostpassword
DB_NAME=ghost

# Required only when running the local "db" container (local-db profile)
DATABASE_ROOT_PASSWORD=reallysecurerootpassword

# --- S3 Storage Configuration (optional) ---
# Leave S3_ACCESS_KEY unset to use local disk storage.
# S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_REGION=eu-central-1
# S3_BUCKET=my-ghost-bucket
# S3_ASSET_HOST=https://assets.example.com
# S3_PATH_PREFIX=blog

# --- Email Configuration (SMTP) ---
# Transactional email is required for logins, staff invites, and password resets.
MAIL_FROM=noreply@example.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx

# --- ActivityPub ---
# If you'd prefer to self-host ActivityPub yourself uncomment the line below
# ACTIVITYPUB_TARGET=activitypub:8080

# --- Tinybird configuration ---
# If you want to run Analytics, paste the output from `docker compose run --rm tinybird-login get-tokens` below
# TINYBIRD_API_URL=https://api.tinybird.co
# TINYBIRD_TRACKER_TOKEN=p.eyJxxxxx
# TINYBIRD_ADMIN_TOKEN=p.eyJxxxxx
# TINYBIRD_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Advanced ---

# Force Ghost version (only if you need to pin a specific version)
# GHOST_VERSION=6-alpine

# Data locations
UPLOAD_LOCATION=./data/ghost
MYSQL_DATA_LOCATION=./data/mysql
